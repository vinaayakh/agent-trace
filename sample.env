# Copy this file to .env and fill in your values.
# None of these are required — only set the keys for providers you use.

# ── LLM provider keys ─────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...          # Free tier: https://console.groq.com

# ── agent-trace exporter ──────────────────────────────────────────────────────

# "otlp"    → send traces to Jaeger (start with .\scripts\start_jaeger.ps1)
# "console" → print spans to stdout, no backend needed
AGENT_TRACE_EXPORTER=otlp

# OTLP endpoint (only used when AGENT_TRACE_EXPORTER=otlp)
# Default targets a local Jaeger instance started by start_jaeger.ps1
AGENT_TRACE_OTLP_ENDPOINT=http://localhost:4318/v1/traces
